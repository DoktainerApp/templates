{
  "id": "pgadmin",
  "name": "pgAdmin",
  "desc": "Web-based administration tool for PostgreSQL databases",
  "category": "DevOps",
  "image": "dpage/pgadmin4:latest",
  "defaultPort": "8088:80",
  "defaultEnv": "PGADMIN_DEFAULT_EMAIL=admin@example.com\nPGADMIN_DEFAULT_PASSWORD=admin\nPGADMIN_LISTEN_PORT=80\nPGADMIN_CONFIG_SERVER_MODE=True",
  "defaultVolumes": "/srv/pgadmin:/var/lib/pgadmin",
  "restartPolicy": "unless-stopped",
  "popular": false,
  "tags": [
    "PostgreSQL",
    "GUI"
  ],
  "presentation": {
    "icon": "https://cdn.simpleicons.org/postgresql/4169E1",
    "installs": 270
  }
}
